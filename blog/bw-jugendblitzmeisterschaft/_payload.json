[{"data":1,"prerenderedAt":238},["Reactive",2],{"navigation":3,"/blog/bw-jugendblitzmeisterschaft":56,"/blog/bw-jugendblitzmeisterschaft-surround":151,"footer":162},[4,47,50,53],{"title":5,"_path":6,"children":7},"Blog","/blog",[8,11,14,17,20,23,26,29,32,35,38,41,44],{"title":9,"_path":10},"DVM U14 2016 in Düsseldorf","/blog/dvm-u14-2016",{"title":12,"_path":13},"6. Biberacher Jugend-Pokalturnier 2017: Ergebnisse","/blog/ergebnisse-6-biberach-jugend-pokalturnier",{"title":15,"_path":16},"7. Biber-Jugend-Cup 2017: Ergebnisse","/blog/ergebnisse-7-biber-jugend-cup",{"title":18,"_path":19},"Erfolgreiche Ausrichtung des Biber-Jugend-Cups und des Biber-Jugend-Pokals 2018","/blog/biber-jugend-cup-pokal",{"title":21,"_path":22},"BW-Jugendblitzmeisterschaft 2018","/blog/bw-jugendblitzmeisterschaft",{"title":24,"_path":25},"WVMM 2018","/blog/wvmm-2018",{"title":27,"_path":28},"BW-Mannschaftsfinale U16 2018","/blog/bw-mannschaftsfinale-u16",{"title":30,"_path":31},"8. Biberacher Jugend-Pokalturnier 2019: Ergebnisse","/blog/ergebnisse-8-biberach-jugend-pokalturnier",{"title":33,"_path":34},"9. Biber-Jugend-Cup 2019: Ergebnisse","/blog/ergebnisse-9-biber-jugend-cup",{"title":36,"_path":37},"Lizenzverlängerung B- und C-Trainer in Ruit","/blog/lizenzverlangerung-in-ruit",{"title":39,"_path":40},"9. Biber-Jugend-Cup - Dank und Ausblick","/blog/9-biber-jugend-cup-dank-und-ausblick",{"title":42,"_path":43},"WVMM 2019 - Biberach holt Meistertitel","/blog/biberach-holt-meistertitel",{"title":45,"_path":46},"Jugendbundesliga Süd 2019/20 (Karlsruher SF 1)","/blog/jugendbundesliga-sued",{"title":48,"_path":49},"Schachfreunde Heilbronn-Biberach 1978 e. V.","/",{"title":51,"_path":52},"Mannschaften","/mannschaften",{"title":54,"_path":55},"Turniere","/turniere",{"_path":22,"_dir":57,"_draft":58,"_partial":58,"_locale":59,"title":21,"description":60,"date":61,"badge":62,"body":63,"_type":146,"_id":147,"_source":148,"_file":149,"_extension":150},"blog",false,"","Erfolgreiche Bilanz der Biberacher Schachtalente bei den BW-Blitzmeisterschaften: Titelgewinn, Vizemeistertitel und starke Einzelleistungen in verschiedenen Altersklassen.","2018-03-25T00:00:00.000Z","Jugend",{"type":64,"children":65,"toc":143},"root",[66,74,79,84,89,94,99,104,109],{"type":67,"tag":68,"props":69,"children":70},"element","p",{},[71],{"type":72,"value":73},"text","In der U10 landete Rodrigo Melzig in einem starken Teilnehmerfeld mit 10 Punkten aus 14 Runden auf dem 5. Platz. Lediglich ein halber Punkt trennte ihn vom 3. Platz.",{"type":67,"tag":68,"props":75,"children":76},{},[77],{"type":72,"value":78},"In der U12 starteten mit Sriram Iyengar und Elia Dittmar zwei Jungs. Während es bei Elia nicht ganz so lief (8. Platz / 6 Punkte) überzeugte unser Sriram, der eigentlich nicht dafür bekannt ist, ein toller Blitzer zu sein, mit großer Konstanz, und Ruhe am Brett. Mit 8 Punkten aus 12 Runden wurde er 3. Etwas ärgerlich dabei, dass er in der letzten Runde, gegen den Gesamtsieger eine Gewinnstellung auf dem Brett hatte, die er etwas überhastet noch verlor. Trotzdem dein toller Erfolg.",{"type":67,"tag":68,"props":80,"children":81},{},[82],{"type":72,"value":83},"Simeon Triantafillidis und Noah Geltz starteten in der U14. Und Noah erwischte einen Sahnetag. Mit 8 Siegen in Folge zeigte Noah auch auf BW-Ebene seine Klasse. Gegen Ende ging ihm etwas die Luft aus, aber mit 11,5 Punkten aus 16 Runden (die U14 spielte mit der U16, U18 und U20 in einem Feld bei separater Wertung) distanzierte er die U14 Konkurrenz um 1,5 Punkte und wurde verdienter BW-Blitzmeister! Simeon landete mit 9 Punkten auf dem undankbaren 4. Rang, der auch sehr bitter zustande kam. Gegen den Zweitplatzierten Linus Koll aus Karlsruhe schaffte es Simeon in hoher Zeitnot, seinen Gegner Patt zu setzen. Ein Sieg in dieser Partie hätte ihm den 2. Platz beschert. Wie gut unsere zwei U14er drauf waren zeigt, der Sieg der beiden gegen einen FM (>2200).",{"type":67,"tag":68,"props":85,"children":86},{},[87],{"type":72,"value":88},"Ebenfalls 9 Punkte erzielte Jens Hoffmann, der am Ende toller Vizemeister der U16 wurde.",{"type":67,"tag":68,"props":90,"children":91},{},[92],{"type":72,"value":93},"In der U18 spielte Alexander Eurich, der einen nicht ganz so guten Tag erwischte. Trotzdem reichte es mit 7,5 Punkten zur Vizemeisterschaft in der U18.",{"type":67,"tag":68,"props":95,"children":96},{},[97],{"type":72,"value":98},"Last but not least, komplettierte Alexander Arns in der U20 unseren Biberach-Achter. Auch Alexander erreichte 9 Punkte und wurde Vizemeister in der U20!",{"type":67,"tag":68,"props":100,"children":101},{},[102],{"type":72,"value":103},"Alles in allem kann sich das Abschneiden der Biberacher Jungs sehen lassen: 1 Titel, 2x Vizemeister und 2 Dritte Plätze sind ein tolles Ergebnis.",{"type":67,"tag":68,"props":105,"children":106},{},[107],{"type":72,"value":108},"Weiterführende Links:",{"type":67,"tag":110,"props":111,"children":112},"ul",{},[113,125,134],{"type":67,"tag":114,"props":115,"children":116},"li",{},[117],{"type":67,"tag":118,"props":119,"children":123},"a",{"href":120,"rel":121},"http://schachjugend-baden.de/2018/03/darja-fischer-gewinnt-die-u10-bw-blitzmeisterschaft/",[122],"nofollow",[124],{"type":72,"value":120},{"type":67,"tag":114,"props":126,"children":127},{},[128],{"type":67,"tag":118,"props":129,"children":132},{"href":130,"rel":131},"http://schachjugend-baden.de/2018/03/dirk-becker-martin-hartmann-noah-geltz-und-lukas-koll-gewinnen-in-der-koenigsklasse/",[122],[133],{"type":72,"value":130},{"type":67,"tag":114,"props":135,"children":136},{},[137],{"type":67,"tag":118,"props":138,"children":141},{"href":139,"rel":140},"http://schachjugend-baden.de/2018/03/maximilian-wehrle-ist-bw-blitzmeister-u12/",[122],[142],{"type":72,"value":139},{"title":59,"searchDepth":144,"depth":144,"links":145},2,[],"markdown","content:blog:20180325.bw-jugendblitzmeisterschaft.md","content","blog/20180325.bw-jugendblitzmeisterschaft.md","md",[152,157],{"_path":25,"_dir":57,"_draft":58,"_partial":58,"_locale":59,"title":24,"description":153,"date":154,"badge":62,"_type":146,"_id":155,"_source":148,"_file":156,"_extension":150},"Erfolgreiche Teilnahme in allen Altersklassen: U16 sichert sich Vizemeistertitel und Qualifikation für die Deutsche Meisterschaft.","2018-05-01T00:00:00.000Z","content:blog:20180501.wvmm-2018.md","blog/20180501.wvmm-2018.md",{"_path":19,"_dir":57,"_draft":58,"_partial":58,"_locale":59,"title":18,"description":158,"date":159,"badge":62,"_type":146,"_id":160,"_source":148,"_file":161,"_extension":150},"Eindrücke vom Biber-Jugend-Cup und -Pokal 2018: Eine Zusammenfassung der Höhepunkte, Teilnehmererfolge und organisatorischen Herausforderungen eines bemerkenswerten Schachevents.","2018-03-04T00:00:00.000Z","content:blog:20180304.biber-jugend-cup-pokal.md","blog/20180304.biber-jugend-cup-pokal.md",[163,201],{"_path":164,"_dir":165,"_draft":58,"_partial":166,"_locale":59,"title":167,"description":168,"navigation":58,"body":169,"_type":146,"_id":199,"_source":148,"_file":200,"_extension":150},"/_footer/spiellokal","_footer",true,"Spiellokal","Grundschule Biberach\nBibersteige 9\n74078 Heilbronn-Biberach\n2. Stock, Vereinseingang\n(neben Hallenbad)",{"type":64,"children":170,"toc":197},[171],{"type":67,"tag":68,"props":172,"children":173},{},[174,176,180,182,185,187,190,192,195],{"type":72,"value":175},"Grundschule Biberach",{"type":67,"tag":177,"props":178,"children":179},"br",{},[],{"type":72,"value":181},"\nBibersteige 9",{"type":67,"tag":177,"props":183,"children":184},{},[],{"type":72,"value":186},"\n74078 Heilbronn-Biberach",{"type":67,"tag":177,"props":188,"children":189},{},[],{"type":72,"value":191},"\n2. Stock, Vereinseingang",{"type":67,"tag":177,"props":193,"children":194},{},[],{"type":72,"value":196},"\n(neben Hallenbad)",{"title":59,"searchDepth":144,"depth":144,"links":198},[],"content:_footer:1.spiellokal.md","_footer/1.spiellokal.md",{"_path":202,"_dir":165,"_draft":58,"_partial":166,"_locale":59,"title