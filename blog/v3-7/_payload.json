716},{"style":339},[717],{"type":32,"value":718},"    }\n",{"type":26,"tag":309,"props":720,"children":722},{"class":311,"line":721},14,[723],{"type":26,"tag":309,"props":724,"children":725},{"style":339},[726],{"type":32,"value":389},{"type":26,"tag":309,"props":728,"children":730},{"class":311,"line":729},15,[731,735],{"type":26,"tag":309,"props":732,"children":733},{"style":339},[734],{"type":32,"value":398},{"type":26,"tag":309,"props":736,"children":737},{"style":333},[738],{"type":32,"value":403},{"type":26,"tag":27,"props":740,"children":742},{"id":741},"️-vite-44",[743],{"type":32,"value":744},"⚡️ Vite 4.4",{"type":26,"tag":35,"props":746,"children":747},{},[748],{"type":32,"value":749},"We've chosen to unpin Vite from minor versions, meaning whenever Vite releases a new feature version you can opt-in straight away. Vite 4.4 brings a lot of exciting things, including experimental Lightning CSS support - and much more!",{"type":26,"tag":35,"props":751,"children":752},{},[753,755,762],{"type":32,"value":754},"👉 Check out the ",{"type":26,"tag":50,"props":756,"children":759},{"href":757,"rel":758},"https://github.com/vitejs/vite/blob/main/packages/vite/CHANGELOG.md#440-2023-07-06",[54],[760],{"type":32,"value":761},"Vite release notes",{"type":32,"value":763}," for more.",{"type":26,"tag":27,"props":765,"children":767},{"id":766},"typescript-updates",[768],{"type":32,"value":769},"💪 TypeScript Updates",{"type":26,"tag":35,"props":771,"children":772},{},[773,775,781,783,789,791,798],{"type":32,"value":774},"We now use purely relative paths in the generated ",{"type":26,"tag":41,"props":776,"children":778},{"className":777},[],[779],{"type":32,"value":780},"tsconfig.json",{"type":32,"value":782}," instead of setting a ",{"type":26,"tag":41,"props":784,"children":786},{"className":785},[],[787],{"type":32,"value":788},"baseUrl",{"type":32,"value":790},". This means better support for dev environments like docker images where the absolute path may not match your IDE (",{"type":26,"tag":50,"props":792,"children":795},{"href":793,"rel":794},"https://github.com/nuxt/nuxt/pull/22410",[54],[796],{"type":32,"value":797},"#22410",{"type":32,"value":799},").",{"type":26,"tag":35,"props":801,"children":802},{},[803,805,812],{"type":32,"value":804},"We also set a couple of additional compiler flag defaults to match Vite/TS recommendations (",{"type":26,"tag":50,"props":806,"children":809},{"href":807,"rel":808},"https://github.com/nuxt/nuxt/pull/22468",[54],[810],{"type":32,"value":811},"#22468",{"type":32,"value":799},{"type":26,"tag":35,"props":814,"children":815},{},[816,818,824,826,832,833,840],{"type":32,"value":817},"Plus, you should now get type hinted access to layouts in ",{"type":26,"tag":41,"props":819,"children":821},{"className":820},[],[822],{"type":32,"value":823},"setPageLayout",{"type":32,"value":825}," and also in ",{"type":26,"tag":41,"props":827,"children":829},{"className":828},[],[830],{"type":32,"value":831},"\u003CNuxtLayout name>",{"type":32,"value":214},{"type":26,"tag":50,"props":834,"children":837},{"href":835,"rel":836},"https://github.com/nuxt/nuxt/pull/22362",[54],[838],{"type":32,"value":839},"#22363",{"type":32,"value":799},{"type":26,"tag":27,"props":842,"children":844},{"id":843},"async-context-support",[845],{"type":32,"value":846},"🦄 Async Context support",{"type":26,"tag":35,"props":848,"children":849},{},[850,852,859],{"type":32,"value":851},"If you've ever got an issue with 'Nuxt context unavailable' this might be one for you. We now support  native async context for Bun and Node under an experimental flag, in both Nuxt and Nitro (",{"type":26,"tag":50,"props":853,"children":856},{"href":854,"rel":855},"https://github.com/nuxt/nuxt/pull/20918",[54],[857],{"type":32,"value":858},"#20918",{"type":32,"value":799},{"type":26,"tag":35,"props":861,"children":862},{},[863,865,870,872,878],{"type":32,"value":864},"This enables using Nuxt composables on the server ",{"type":26,"tag":161,"props":866,"children":867},{},[868],{"type":32,"value":869},"without",{"type":32,"value":871}," needing to ensure they are being called directly in a setup function. It also allows the same in Nitro, with a new ",{"type":26,"tag":41,"props":873,"children":875},{"className":874},[],[876],{"type":32,"value":877},"useEvent()",{"type":32,"value":879}," utility that is usable in server routes.",{"type":26,"tag":35,"props":881,"children":882},{},[883,885,891],{"type":32,"value":884},"To try it out, you can enable ",{"type":26,"tag":41,"props":886,"children":888},{"className":887},[],[889],{"type":32,"value":890},"experimental.asyncContext",{"type":32,"value":297},{"type":26,"tag":299,"props":893,"children":895},{"className":301,"code":894,"language":303,"meta":7,"style":7},"export default defineNuxtConfig({\n  experimental: {\n    asyncContext: true\n  }\n})\n",[896],{"type":26,"tag":41,"props":897,"children":898},{"__ignoreMap":7},[899,922,937,953,960],{"type":26,"tag":309,"props":900,"children":901},{"class":311,"line":312},[902,906,910,914,918],{"type":26,"tag":309,"props":903,"children":904},{"style":316},[905],{"type":32,"value":319},{"type":26,"tag":309,"props":907,"children":908},{"style":316},[909],{"type":32,"value":324},{"type":26,"tag":309,"props":911,"children":912},{"style":327},[913],{"type":32,"value":330},{"type":26,"tag":309,"props":915,"children":916},{"style":333},[917],{"type":32,"value":336},{"type":26,"tag":309,"props":919,"children":920},{"style":339},[921],{"type":32,"value":342},{"type":26,"tag":309,"props":923,"children":924},{"class":311,"line":345},[925,929,933],{"type":26,"tag":309,"props":926,"children":927},{"style":349},[928],{"type":32,"value":352},{"type":26,"tag":309,"props":930,"children":931},{"style":339},[932],{"type":32,"value":297},{"type":26,"tag":309,"props":934,"children":935},{"style":339},[936],{"type":32,"value":361},{"type":26,"tag":309,"props":938,"children":939},{"class":311,"line":364},[940,945,949],{"type":26,"tag":309,"props":941,"children":942},{"style":349},[943],{"type":32,"value":944},"    asyncContext",{"type":26,"tag":309,"props":946,"children":947},{"style":339},[948],{"type":32,"value":297},{"type":26,"tag":309,"props":950,"children":951},{"style":377},[952],{"type":32,"value":380},{"type":26,"tag":309,"props":954,"children":955},{"class":311,"line":383},[956],{"type":26,"tag":309,"props":957,"children":958},{"style":339},[959],{"type":32,"value":389},{"type":26,"tag":309,"props":961,"children":962},{"class":311,"line":392},[963,967],{"type":26,"tag":309,"props":964,"children":965},{"style":339},[966],{"type":32,"value":398},{"type":26,"tag":309,"props":968,"children":969},{"style":333},[970],{"type":32,"value":403},{"type":26,"tag":27,"props":972,"children":974},{"id":973},"watcher-updates",[975],{"type":32,"value":976},"👓 Watcher Updates",{"type":26,"tag":35,"props":978,"children":979},{},[980],{"type":32,"value":981},"We've fixed a couple of issues with watchers, meaning that you should need to restart your server less often - and you should see a significant performance increase if you are using layers.",{"type":26,"tag":27,"props":983,"children":985},{"id":984},"️-nitro-26",[986],{"type":32,"value":987},"⚗️ Nitro 2.6",{"type":26,"tag":35,"props":989,"children":990},{},[991,993,999],{"type":32,"value":992},"There lots more exciting features coming directly from Nitro 2.6, including smaller, lighter servers and new persistent data storage in a ",{"type":26,"tag":41,"props":994,"children":996},{"className":995},[],[997],{"type":32,"value":998},".data",{"type":32,"value":1000}," directory.",{"type":26,"tag":35,"props":1002,"children":1003},{},[1004,1006,1013],{"type":32,"value":1005},"👉 Read more in ",{"type":26,"tag":50,"props":1007,"children":1010},{"href":1008,"rel":1009},"https://unjs.io/blog/2023-08-25-nitro-2.6",[54],[1011],{"type":32,"value":1012},"the full release article",{"type":32,"value":417},{"type":26,"tag":1015,"props":1016,"children":1018},"h2",{"id":1017},"upgrading",[101