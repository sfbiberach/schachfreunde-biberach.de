[{"data":1,"prerenderedAt":245},["Reactive",2],{"navigation":3,"/blog/biberach-holt-meistertitel":56,"/blog/biberach-holt-meistertitel-surround":146,"users/Jens Hoffmann":157,"users/Dimitrios Triantafillidis":165,"footer":170},[4,47,50,53],{"title":5,"_path":6,"children":7},"Blog","/blog",[8,11,14,17,20,23,26,29,32,35,38,41,44],{"title":9,"_path":10},"DVM U14 2016 in Düsseldorf","/blog/dvm-u14-2016",{"title":12,"_path":13},"6. Biberacher Jugend-Pokalturnier 2017: Ergebnisse","/blog/ergebnisse-6-biberach-jugend-pokalturnier",{"title":15,"_path":16},"7. Biber-Jugend-Cup 2017: Ergebnisse","/blog/ergebnisse-7-biber-jugend-cup",{"title":18,"_path":19},"Erfolgreiche Ausrichtung des Biber-Jugend-Cups und des Biber-Jugend-Pokals 2018","/blog/biber-jugend-cup-pokal",{"title":21,"_path":22},"BW-Jugendblitzmeisterschaft 2018","/blog/bw-jugendblitzmeisterschaft",{"title":24,"_path":25},"WVMM 2018","/blog/wvmm-2018",{"title":27,"_path":28},"BW-Mannschaftsfinale U16 2018","/blog/bw-mannschaftsfinale-u16",{"title":30,"_path":31},"8. Biberacher Jugend-Pokalturnier 2019: Ergebnisse","/blog/ergebnisse-8-biberach-jugend-pokalturnier",{"title":33,"_path":34},"9. Biber-Jugend-Cup 2019: Ergebnisse","/blog/ergebnisse-9-biber-jugend-cup",{"title":36,"_path":37},"Lizenzverlängerung B- und C-Trainer in Ruit","/blog/lizenzverlangerung-in-ruit",{"title":39,"_path":40},"9. Biber-Jugend-Cup - Dank und Ausblick","/blog/9-biber-jugend-cup-dank-und-ausblick",{"title":42,"_path":43},"WVMM 2019 - Biberach holt Meistertitel","/blog/biberach-holt-meistertitel",{"title":45,"_path":46},"Jugendbundesliga Süd 2019/20 (Karlsruher SF 1)","/blog/jugendbundesliga-sued",{"title":48,"_path":49},"Schachfreunde Heilbronn-Biberach 1978 e. V.","/",{"title":51,"_path":52},"Mannschaften","/mannschaften",{"title":54,"_path":55},"Turniere","/turniere",{"_path":43,"_dir":57,"_draft":58,"_partial":58,"_locale":59,"title":42,"description":60,"date":61,"badge":62,"authors":63,"body":66,"_type":141,"_id":142,"_source":143,"_file":144,"_extension":145},"blog",false,"","Biberachs Jugendteams glänzen bei den Württembergischen Mannschaftsmeisterschaften in Göppingen, mit einem spektakulären Meistertitel in der U14 und einem beeindruckenden zweiten Platz in der U16..","2019-04-03T00:00:00.000Z","Jugend",[64,65],"Jens Hoffmann","Dimitrios Triantafillidis",{"type":67,"children":68,"toc":138},"root",[69,77,82,87,92,97,102,107,112,117,122,133],{"type":70,"tag":71,"props":72,"children":73},"element","p",{},[74],{"type":75,"value":76},"text","Bei den Württembergischen Mannschaftsmeisterschaften in Göppingen überzeugten die drei Jugendteams des Biberacher Schachklubs:",{"type":70,"tag":71,"props":78,"children":79},{},[80],{"type":75,"value":81},"als Außenseiter startete Biberach mit Elia Dittmar, Sriram Iyengar, Rodrigo Melzig sowie Baran Karaduman in der Altersklasse U14. Nach einem klassischen Fehlstart mit einer Niederlage gegen Spaichingen kämpften sich die Biberacher mit drei knappen Siegen gegen Bebenhausen, Murrhardt sowie den Gastgeber in der Tabelle nach vorne.",{"type":70,"tag":71,"props":83,"children":84},{},[85],{"type":75,"value":86},"Das Derby in der 5. Runde gegen den favorisierten Heilbronner SchV endete mit einem hart umkämpften Unentschieden.",{"type":70,"tag":71,"props":88,"children":89},{},[90],{"type":75,"value":91},"In der Schlussrunde reichte daher ein knapper glücklicher Sieg gegen Kornwestheim zum unerwarteten Meistertitel. Bester Scorer war Rodrigo Melzig, der aus 7 Partien hervorragende 5,5 Punkte erzielte.",{"type":70,"tag":71,"props":93,"children":94},{},[95],{"type":75,"value":96},"In der U16 gingen Noah Geltz, Simeon Triantafillidis, Robin Gerold und René Späth an die Bretter. Das Team, das seit vier Jahren unverändert zusammenspielt, ist mittlerweile so eingespielt, dass in den ersten fünf Matches nichts anbrannte und die Qualifikation bereits vor der letzten Runde feststand.",{"type":70,"tag":71,"props":98,"children":99},{},[100],{"type":75,"value":101},"Es kam zum Showdown in der letzten Runde gegen den amtierenden deutschen Meister Kornwestheim. Bei Mannschafts- und Brettpunkte lagen beide Mannschaften gleichauf.",{"type":70,"tag":71,"props":103,"children":104},{},[105],{"type":75,"value":106},"Eine Sekunde war letztlich das Zünglein an der Waage: beim Stande von 0,5 – 1,5 machte Triantafillidis in vorteilhafter Stellung und bei Zeitvorteil einen überhasteten Zug. Sein Gegner gab daraufhin ein vermeintliches Schachgebot, das sich mit einer Sekunde auf der Uhr des Gegners als Matt herausstellte. Damit war die Biberacher Gegenwehr gebrochen.",{"type":70,"tag":71,"props":108,"children":109},{},[110],{"type":75,"value":111},"Zur großen Freude Kornwestheimer natürlich, dies das Duell dann doch etwas zu hoch mit 3,5-0,5 für sich entscheiden konnten. Biberach wurde Zweiter, nahm es sportlich und freut sich schon jetzt auf die Stichkämpfe gegen die Badener Vereine.",{"type":70,"tag":71,"props":113,"children":114},{},[115],{"type":75,"value":116},"Komplettiert wurde das gute Abschneiden durch einen 6. Platz in der U12, punktgleich mit Rang 4. Das Resultat ist bemerkenswert, da die Mannschaft auch  aus unerfahreneren U8- und U10-Spielern bestand, die an den Turniersport gerade herangeführt werden.",{"type":70,"tag":71,"props":118,"children":119},{},[120],{"type":75,"value":121},"Einzelheiten erfahrt ihr im umfangreichen Bericht von Dimi:",{"type":70,"tag":71,"props":123,"children":124},{},[125],{"type":70,"tag":126,"props":127,"children":130},"a",{"external":59,"href":128,"target":129},"/assets/blog/20190403.biberach-holt-meistertitel/190330-WVMM-in-Goeppingen.pdf","_blank",[131],{"type":75,"value":132},"Bericht (pdf, ca. 800 kb)",{"type":70,"tag":71,"props":134,"children":135},{},[136],{"type":75,"value":137},"(me)",{"title":59,"searchDepth":139,"depth":139,"links":140},2,[],"markdown","content:blog:20190403.biberach-holt-meistertitel.md","content","blog/20190403.biberach-holt-meistertitel.md","md",[147,152],{"_path":46,"_dir":57,"_draft":58,"_partial":58,"_locale":59,"title":45,"description":148,"date":149,"badge":62,"authors":64,"_type":141,"_id":150,"_source":143,"_file":151,"_extension":145},"Herausforderung gegen den Titelverteidiger: Biberacher Jugend zeigt Kampfgeist trotz Niederlage in der Jugendbundesliga Süd.","2019-10-12T00:00:00.000Z","content:blog:20191012.jugendbundesliga-sued.md","blog/20191012.jugendbundesliga-sued.md",{"_path":40,"_dir":57,"_draft":58,"_partial":58,"_locale":59,"title":39,"description":153,"date":154,"badge":62,"_type":141,"_id":155,"_source":143,"_file":156,"_extension":145},"Erfolgreicher 9. Biber-Jugend-Cup: Rekordbeteiligung und herzlicher Dank an Helfer und Sponsoren – Vorfreude auf die 10. Ausgabe im Jahr 2020.","2019-03-13T00:00:00.000Z","content:blog:20190313.9-biber-jugend-cup-dank-und-ausblick.md","blog/20190313.9-biber-jugend-cup-dank-und-ausblick.md",{"_path":158,"_dir":159,"_draft":58,"_partial":160,"_locale":59,"name":64,"to":161,"_id":162,"_type":163,"title":64,"_source":143,"_file":164,"_extension":163},"/_users/jens-hoffmann","_users",true,"https://www.instagram.com/oeko.jens/","content:_users:Jens Hoffmann.yaml","yaml","_users/Jens Hoffmann.yaml",{"_path":166,"_dir":159,"_draft":58,"_partial":160,"_locale":59,"name":65,"to":167,"_id":168,"_type":163,"title":65,"_source":143,"_file":169,"_extension":163},"/_users/dimitrios-triantafillidis","https://www.instagram.com/dimitraculix/","content:_users:Dimitrios Triantafillidis.yaml","_users/Dimitrios Triantafillidis.yaml",[171,208],{"_path":172,"_dir":173,"_draft":58,"_partial":160,"_locale":59,"title":174,"description":175,"navigation":58,"body":176,"_type":141,"_id":206,"_source":143,"_file":207,"_extension":145},"/_footer/spiellokal","_footer","Spiellokal","Grundschule Biberach\nBibersteige 9\n74078 Heilbronn-Biberach\n2. Stock, Vereinseingang\n(neben Hallenbad)",{"type":67,"children":177,"toc":204},[178],{"type":70,"tag":71,"props":179,"children":180},{},[181,183,187,189,192,194,197,199,202],{"