[{"data":1,"prerenderedAt":152},["Reactive",2],{"/blog/9-biber-jugend-cup-dank-und-ausblick":3,"/blog/9-biber-jugend-cup-dank-und-ausblick-surround":59,"footer":78},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"date":10,"badge":11,"body":12,"_type":54,"_id":55,"_source":56,"_file":57,"_extension":58},"/blog/9-biber-jugend-cup-dank-und-ausblick","blog",false,"","9. Biber-Jugend-Cup - Dank und Ausblick","Erfolgreicher 9. Biber-Jugend-Cup: Rekordbeteiligung und herzlicher Dank an Helfer und Sponsoren – Vorfreude auf die 10. Ausgabe im Jahr 2020.","2019-03-13T00:00:00.000Z","Jugend",{"type":13,"children":14,"toc":51},"root",[15,23,28,33],{"type":16,"tag":17,"props":18,"children":19},"element","p",{},[20],{"type":21,"value":22},"text","Der Biber-Jugend-Cup 2019 und das Biberacher Jugend-Pokalturnier sind bereits Geschichte. Wir konnten uns über einen neuen Teilnehmerrekord freuen.",{"type":16,"tag":17,"props":24,"children":25},{},[26],{"type":21,"value":27},"193 Kinder und Jugendliche standen am Samstag im Mittelpunkt und konnten sich an den Brettern sportlich messen. Wir bedanken uns bei Euch für das entgegengebrachte Vertrauen. Eure positive Rückmeldungen sind uns weiter Ansporn. Kritik ist willkommen, damit wir noch besser werden und das Turnier für Euch optimieren können.",{"type":16,"tag":17,"props":29,"children":30},{},[31],{"type":21,"value":32},"Ein herzliches Dankeschön gilt allen Helfern im Vorder- und Hintergrund, Unterstützern und Sponsoren, die dieses Turnier überhaupt möglich gemacht haben.",{"type":16,"tag":17,"props":34,"children":35},{},[36,42,46],{"type":16,"tag":37,"props":38,"children":39},"strong",{},[40],{"type":21,"value":41},"Gleich vormerken:",{"type":16,"tag":43,"props":44,"children":45},"br",{},[],{"type":16,"tag":37,"props":47,"children":48},{},[49],{"type":21,"value":50},"Der 10. Biber-Jugend-Cup 2020 findet am 29. Februar 2020 statt. Wir freuen uns auf Euer Kommen!",{"title":7,"searchDepth":52,"depth":52,