84}," & ",{"type":29,"tag":190,"props":286,"children":289},{"href":287,"rel":288},"https://headlessui.com/",[194],[290],{"type":34,"value":291},"Headless UI",{"type":34,"value":293},".",{"type":29,"tag":30,"props":295,"children":296},{},[297,299,306],{"type":34,"value":298},"The website also uses ",{"type":29,"tag":190,"props":300,"children":303},{"href":301,"rel":302},"https://ui.nuxt.com/pro",[194],[304],{"type":34,"value":305},"Nuxt UI Pro",{"type":34,"value":307},", a set of premium components built on top of Nuxt UI to create beautiful & responsive Nuxt applications in minutes.",{"type":29,"tag":30,"props":309,"children":310},{},[311,313,319,321,327,328,334,335,341],{"type":34,"value":312},"It includes components such as ",{"type":29,"tag":57,"props":314,"children":316},{"className":315},[],[317],{"type":34,"value":318},"\u003CUHeader>",{"type":34,"value":320},", ",{"type":29,"tag":57,"props":322,"children":324},{"className":323},[],[325],{"type":34,"value":326},"\u003CUFooter>",{"type":34,"value":320},{"type":29,"tag":57,"props":329,"children":331},{"className":330},[],[332],{"type":34,"value":333},"\u003CULandingHero>",{"type":34,"value":320},{"type":29,"tag":57,"props":336,"children":338},{"className":337},[],[339],{"type":34,"value":340},"\u003CULandingCard>",{"type":34,"value":342}," and more.",{"type":29,"tag":344,"props":345,"children":348},"callout",{"icon":346,"color":347},"i-ph-info-duotone","blue",[349],{"type":29,"tag":30,"props":350,"children":351},{},[352,354,361],{"type":34,"value":353},"We plan to launch the full documentation of Nuxt UI Pro at the end of October. If you cannot wait and want early access, you can already ",{"type":29,"tag":190,"props":355,"children":358},{"href":356,"rel":357},"https://ui.nuxt.com/pro/purchase",[194],[359],{"type":34,"value":360},"purchase a license",{"type":34,"value":362}," now and get access to our private repository on GitHub.",{"type":29,"tag":30,"props":364,"children":365},{},[366,368,375,377,385,387,394],