{"type":34,"value":77},"We wanted to achieve a consistent design across all our official documentations:",{"type":29,"tag":30,"props":79,"children":80},{},[81,83],{"type":34,"value":82},"We really love this new design and hope you do too. ",{"type":29,"tag":37,"props":84,"children":85},{},[86],{"type":34,"value":87},"This is only the first step toward many improvements coming to the website.",{"type":29,"tag":45,"props":89,"children":91},{"id":90},"improved-navigation",[92],{"type":34,"value":93},"Improved Navigation",{"type":29,"tag":30,"props":95,"children":96},{},[97],{"type":34,"value":98},"From now on, you can easily jump between the five main documentation categories:",{"type":29,"tag":100,"props":101,"children":109},"video",{":controls":102,"className":103,"controls":107,"poster":108},"true",[104,105,106],"rounded","dark:border","dark:border-gray-700",true,"https://res.cloudinary.com/nuxt/video/upload/v1697548111/nuxt3/nuxt-website-docs-nav.jpg",[110,116,121],{"type":29,"tag":111,"props":112,"children":115},"source",{"src":113,"type":114},"https://res.cloudinary.com/nuxt/video/upload/v1697548111/nuxt3/nuxt-website-docs-nav.webm","video/webm",[],{"type":29,"tag":111,"props":117,"children":120},{"src":118,"type":119},"https://res.cloudinary.com/nuxt/video/upload/v1697548111/nuxt3/nuxt-website-docs-nav.mp4","video/mp4",[],{"type":29,"tag":111,"props":122,"children":125},{"src":123,"type":124},"https://res.cloudinary.com/nuxt/video/upload/v1697548111/nuxt3/nuxt-website-docs-nav.ogg","video/ogg",[],{"type":29,"tag":30,"props":127,"children":128},{},[129],{"type":34,"value":130},"On the right side, you can see the table of contents as well as community shortcuts: Edit this page, Chat on Discord, etc.",{"type":29,"tag":100,"props":132,"children":135},{":controls":102,"className":133,"controls":107,"poster":134},[104,105,106],"https://res.cloudinary.com/nuxt/video/upload/v1697549697/nuxt3/nuxt-website-docs-aside.jpg",[136,140,144],{"type":29,"tag":111,"props":137,"ch