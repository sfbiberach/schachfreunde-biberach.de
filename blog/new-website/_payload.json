ub.com/nuxt/nuxt.com",[448],{"type":29,"tag":30,"props":449,"children":450},{},[451,453,459],{"type":34,"value":452},"Check out ",{"type":29,"tag":57,"props":454,"children":456},{"className":455},[],[457],{"type":34,"value":458},"nuxt/nuxt.com",{"type":34,"value":460}," on GitHub.",{"type":29,"tag":45,"props":462,"children":464},{"id":463},"whats-next",[465],{"type":34,"value":466},"What's next?",{"type":29,"tag":30,"props":468,"children":469},{},[470],{"type":34,"value":471},"This new website is the beginning of upcoming changes we are planing, some of them are:",{"type":29,"tag":210,"props":473,"children":474},{},[475,480,485,499],{"type":29,"tag":214,"props":476,"children":477},{},[478],{"type":34,"value":479},"Team & Contributors pages",{"type":29,"tag":214,"props":481,"children":482},{},[483],{"type":34,"value":484},"Integrations page to showcase all the possibilities with Nuxt: Hosting, CMS, Database, etc.",{"type":29,"tag":214,"props":486,"children":487},{},[488,490,497],{"type":34,"value":489},"Templates page (currently ",{"type":29,"tag":190,"props":491,"children":494},{"href":492,"rel":493},"https://nuxt.new",[194],[495],{"type":34,"value":496},"nuxt.new",{"type":34,"value":498},") to list official and community starters",{"type":29,"tag":214,"props":500,"children":501},{},[502],{"type":34,"value":503},"And more...",{"type":29,"tag":30,"props":505,"children":506},{},[507,535],{"type":29,"tag":37,"props":508,"children":509},{},[510,512,519,520,527,529],{"type":34,"value":511},"We are looking forward to your feedback on ",{"type":29,"tag":190,"props":513,"children":516},{"href":514,"rel":515},"https://twitter.com/nuxt_js",[194],[517],{"type":34,"value":518},"Twitter",{"type":34,"value":320},{"type":29,"tag":190,"props":521,"children":524},{"href":522,"rel":523},"https://discord.com/invite/nuxt",[194],[525],{"type":34,"value":526},"Discord",{"type":34,"value":528}," or ",{"type":29,"tag":190,"props":530,"children":532},{"href":446,"rel":531},[194],[533],{"typ