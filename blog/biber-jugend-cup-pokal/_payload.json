ype":63,"tag":253,"props":599,"children":600},{"align":230},[601],{"type":68,"value":275},{"type":63,"tag":253,"props":603,"children":604},{"align":236},[605],{"type":68,"value":606},"Marc Schallner",{"type":63,"tag":253,"props":608,"children":609},{"align":236},[610],{"type":68,"value":450},{"type":63,"tag":224,"props":612,"children":613},{},[614,618,623],{"type":63,"tag":253,"props":615,"children":616},{"align":230},[617],{"type":68,"value":293},{"type":63,"tag":253,"props":619,"children":620},{"align":236},[621],{"type":68,"value":622},"Florian Ries",{"type":63,"tag":253,"props":624,"children":625},{"align":236},[626],{"type":68,"value":627},"SK Dinkelsbühl",{"type":63,"tag":207,"props":629,"children":631},{"id":630},"altersklasse-u25b",[632],{"type":68,"value":633},"Altersklasse U25B",{"type":68,"value":214},{"type":63,"tag":216,"props":636,"children":637},{},[638,656],{"type":63,"tag":220,"props":639,"children":640},{},[641],{"type":63,"tag":224,"props":642,"children":643},{},[644,648,652],{"type":63,"tag":228,"props":645,"children":646},{"align":230},[647],{"type":68,"value":233},{"type":63,"tag":228,"props":649,"children":650},{"align":236},[651],{"type":68,"value":239},{"type":63,"tag":228,"props":653,"children":654},{"align":236},[655],{"type":68,"value":244},{"type":63,"tag":246,"props":657,"children":658},{},[659,675,692],{"type":63,"tag":224,"props":660,"children":661},{},[662,666,671],{"type":63,"tag":253,"props":663,"children":664},{"align":230},[665],{"type":68,"value":257},{"type":63,"tag":253,"props":667,"children":668},{"align":236},[669],{"type":68,"value":670},"Leon Melzig",{"type":63,"tag":253,"props":672,"children":673},{"align":236},[674],{"type":68,"value":303},{"type":63,"tag":224,"props":676,"children":677},{},[678,682,687],{"type":63,"tag":253,"props":679,"children":680},{"align":230},[681],{"type":68,"value":275},{"type":63,"tag":253,"props":683,"children":684},{"align":236},[685],{"type":68,"value":686},"Sajat Medeuov",{"type":63,"tag":253,"props":688,"children":689},{"align":236},[690],{"type":68,"value":691},"SF Steinsfurt",{"type":63,"tag":224,"props":693,"children":694},{},[695,699,704],{"type":63,"tag":253,"props":696,"children":697},{"align":230},[698],{"type":68,"value":293},{"type":63,"tag":253,"props":700,"children":701},{"align":236},[702],{"type":68,"value":703},"Christian Ries",{"type":63,"tag":253,"props":705,"children":706},{"align":236},[707],{"type":68,"value":627},{"type":63,"tag":64,"props":709,"children":710},{},[711],{"type":68,"value":712},"Die meisten Teilnehmer stellte der Ausrichter (SF HN-Biberach), den Pokal dafür bekamen aber die Spieler aus Dinkelsbühl, die mit 10 Teilnehmern die zweitgrößte Gruppe stellten.",{"type":63,"tag":64,"props":714,"children":715},{},[716],{"type":68,"value":717},"Den Pokal des besten Teams, konnte der RSK Esslingen mit nach Hause nehmen.",{"type":63,"tag":64,"props":719,"children":720},{},[721],{"type":68,"value":722},"Für den Ausrichter Sfr.HN-Biberach war es ein sehr gelungener Schachtag, konnten doch einige der insgesamt 24 Pokale im Ort bleiben. Ebenso freuen wir uns über strahlende Gesichter während der Siegerehrung. Alle Kinder (auch die nicht so ganz erfolgreichen) bekamen eine Goldmedaille und eine Ausgabe der Schachzeitschrift „Jugendschach\" ausgehändigt. Für Spieler mit mind. 4 Punkten gab es dazu obendrauf noch tolle attraktive Preise (Trikots, Schachbücher, etc.) zu gewinnen. Leer ging keines der fast 150 Kinder nach Hause. Alle Ergebnisse können natürlich auf unserer Homepage ausführlicher studiert werden.",{"type":63,"tag":64,"props":724,"children":725},{},[726],{"type":68,"value":727},"Vielen Dank nochmals an dieser Stelle an die vielen ehrenamtlichen Helfer und Helferinnen, die eine solche Ausrichtung überhaupt ermöglicht haben.",{"type":63,"tag":64,"props":729,"children":730},{},[731],{"type":68,"value":732},"Die 9.Auflage des Biber-Jugend-Cups findet in 2019 am 9.März (Faschingsferien) statt. Diesen Termin darf man sich gerne schon mal in den Kalender eintragen.",{"title":56,"searchDepth":92,"depth":92,"links":734},[735,736,737,738,739,740],{"id":209,"depth":92,"text":212},{"id":306,"depth":92,"text":309},{"id":388,"depth":92,"text":391},{"id":470,"depth":92,"text":473},{"id":550,"depth":92,"text":553},{"id":630,"depth":92,"text":633},"content:blog:20180304.biber-jugend-cup-pokal.md","blog/20180304.biber-jugend-cup-pokal.md",[744,749],{"_path":22,"_dir":137,"_draft":54,"_partial":54,"_locale":56,"title":21,"description":745,"date":746,"category":140,"_type":94,"_id":747,"_source":96,"_file":748,"_extension":98},"Erfolgreiche Bilanz der Biberacher Schachtalente bei den BW-Blitzmeisterschaften: Titelgewinn, Vizemeistertitel und starke Einzelleistungen in verschiedenen Altersklassen.","2018-03-25T00:00:00.000Z","content:blog:20180325.bw-jugendblitzmeisterschaft.md","blog/20180325.bw-jugendblitzmeisterschaft.md",{"_path":16,"_dir":137,"_draft":54,"_partial":54,"_locale":56,"title":15,"description":750,"date":751,"category":140,"_type":94,"_id":752,"_source":96,"_file":753,"_extension":98},"Ergebnisse des 7. Biber-Jugend-Cups 2017, Altersklassen U8-U25 in aufsteigender Reihenfolge sortiert.","2017-04-02T00:00:00.000Z","content:blog:20170402.ergebnisse-7-biber-jugend-cup.md","blog/20170402.ergebnisse-7-biber-jugend-cup.md",1711245546551]